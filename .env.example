# Copia este fichero a .env y rellena los valores. El .env NO se versiona (está en .gitignore).

# Clave de API de Groq (obligatoria para que el Extractor y el Consultor funcionen)
GROQ_API_KEY=gsk_tu_clave_de_groq

# Contraseña del SA de SQL Server (mínimo 8 caracteres con mayúscula, minúscula, dígito y símbolo)
MSSQL_SA_PASSWORD=DocFlow_Dev123!

# Ruta al repositorio del frontend para construir su imagen.
# Por defecto asume que está clonado como hermano: ../Frontend_ClasificadorExtractorDocumentos
# En esta máquina de desarrollo, el frontend está en repos_vscode:
# FRONTEND_PATH=../../repos_vscode/ClassificadorExtractorDocumentos
FRONTEND_PATH=../Frontend_ClasificadorExtractorDocumentos
